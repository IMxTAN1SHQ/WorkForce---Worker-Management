{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/owner/dashboard",
      "destination": "/owner/dashboard.html"
    },
    {
      "source": "/owner/workers",
      "destination": "/owner/workers.html"
    },
    {
      "source": "/owner/sites",
      "destination": "/owner/sites.html"
    },
    {
      "source": "/owner/attendance",
      "destination": "/owner/attendance.html"
    },
    {
      "source": "/owner/locations",
      "destination": "/owner/locations.html"
    },
    {
      "source": "/owner/photos",
      "destination": "/owner/photos.html"
    },
    {
      "source": "/worker/dashboard",
      "destination": "/worker/dashboard.html"
    },
    {
      "source": "/worker/attendance",
      "destination": "/worker/attendance.html"
    },
    {
      "source": "/worker/profile",
      "destination": "/worker/profile.html"
    },
    {
      "source": "/worker/upload",
      "destination": "/worker/upload.html"
    },
    {
      "source": "/assets/js/:path*",
      "destination": "/assets/js/:path*"
    },
    {
      "source": "/assets/css/:path*",
      "destination": "/assets/css/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}